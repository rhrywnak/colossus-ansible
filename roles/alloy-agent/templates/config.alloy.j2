// Grafana Alloy agent configuration
// Host: {{ inventory_hostname }} ({{ ansible_host }})
// Generated by Ansible alloy-agent role — do not edit manually
//
// This agent does two things:
//   1. Exposes host metrics (CPU, RAM, disk, network) on :{{ alloy_listen_port }}
//      for Prometheus on VM-314 to scrape
//   2. Pushes journald logs to Loki on VM-314

// ─── Metrics: host-level via unix exporter ───────────────────────
//
// prometheus.exporter.unix is Alloy's built-in equivalent of node_exporter.
// It collects host metrics and registers them on Alloy's HTTP server.
// Prometheus scrapes these at http://{{ ansible_host }}:{{ alloy_listen_port }}/metrics
//
{% if alloy_containerized | default(false) %}
// Running in a container — /proc, /sys, and / are bind-mounted under /host/
prometheus.exporter.unix "host" {
  procfs_path = "/host/proc"
  sysfs_path  = "/host/sys"
  rootfs_path = "/host/root"
}
{% else %}
// Running natively — direct access to host filesystems
prometheus.exporter.unix "host" { }
{% endif %}

/// ─── Metrics: scrape and push to Prometheus ──────────────────────
//
// The unix exporter above creates targets, but they need to be scraped
// and forwarded. This local scrape reads the unix exporter metrics and
// pushes them to central Prometheus via remote_write.
//
// The relabel step ensures the instance label shows the real hostname,
// not the container ID (which is what Podman containers report).
//
prometheus.scrape "node" {
  targets         = prometheus.exporter.unix.host.targets
  forward_to      = [prometheus.relabel.node.receiver]
  scrape_interval = "15s"
  job_name        = "node"
}

prometheus.relabel "node" {
  forward_to = [prometheus.remote_write.prom.receiver]
  rule {
    target_label = "instance"
    replacement  = "{{ inventory_hostname }}"
  }
}

prometheus.remote_write "prom" {
  endpoint {
    url = "http://10.10.100.56:9090/api/v1/write"
  }
}

// ─── Logs: ship journald entries to Loki ─────────────────────────
//
// loki.source.journal reads from systemd's journal. The max_age setting
// prevents a flood of historical logs on first start — only the last
// {{ alloy_journal_max_age }} of entries are shipped.
//
// The "host" label is critical — without it, logs from all hosts would
// be indistinguishable in Loki. We set it to the Ansible inventory name.
//
loki.source.journal "journal" {
{% if alloy_containerized | default(false) %}
  path       = "/var/log/journal"
{% endif %}
  max_age    = "{{ alloy_journal_max_age }}"
  forward_to = [loki.relabel.journal.receiver]
  labels     = {
    job  = "systemd-journal",
    host = "{{ inventory_hostname }}",
  }
}

// ─── Log relabeling: extract useful labels ───────────────────────
//
// Raw journal entries have metadata stored in __journal__* labels.
// We promote the useful ones to first-class Loki labels so you can
// filter in Grafana with queries like:
//   {host="pve-1", unit="pveproxy.service", priority="err"}
//
loki.relabel "journal" {
  forward_to = [loki.write.default.receiver]

  // systemd unit name (e.g., "sshd.service", "podman.service")
  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }

  // syslog priority keyword (e.g., "info", "warning", "err")
  rule {
    source_labels = ["__journal__priority_keyword"]
    target_label  = "priority"
  }

  // transport — how the log entered journald (e.g., "stdout", "syslog", "kernel")
  rule {
    source_labels = ["__journal__transport"]
    target_label  = "transport"
  }
}

// ─── Log destination: push to central Loki ───────────────────────
//
loki.write "default" {
  endpoint {
    url = "{{ alloy_loki_url }}"
  }
}
