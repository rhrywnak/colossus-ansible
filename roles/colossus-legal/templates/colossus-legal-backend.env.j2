# Managed by Ansible — do not edit manually
# Contains secrets — file permissions should be 0600

NEO4J_URI={{ colossus_legal_neo4j_uri }}
NEO4J_USER={{ colossus_legal_neo4j_user }}
NEO4J_PASSWORD={{ _neo4j_password }}
DATABASE_URL={{ _pg_url }}
PIPELINE_DATABASE_URL={{ _pg_url_v2 }}
ANTHROPIC_API_KEY={{ _anthropic_api_key }}
ANTHROPIC_MODEL={{ colossus_legal_anthropic_model | default('claude-sonnet-4-6') }}
QDRANT_URL={{ colossus_legal_qdrant_url }}
FASTEMBED_CACHE_PATH={{ colossus_legal_fastembed_cache_path }}
DOCUMENT_STORAGE_PATH={{ colossus_legal_documents_container_path }}
PIPELINE_REGISTRY_FILE={{ colossus_legal_documents_container_path }}/config/pipeline_registry.yaml
# Legacy directory env vars — fallback when PIPELINE_REGISTRY_FILE is not set.
# Remove after registry is validated on DEV and PROD.
EXTRACTION_TEMPLATE_DIR={{ colossus_legal_documents_container_path }}/extraction_templates
EXTRACTION_SCHEMA_DIR={{ colossus_legal_documents_container_path }}/extraction_schemas
PROCESSING_PROFILE_DIR={{ colossus_legal_documents_container_path }}/profiles
SYSTEM_PROMPT_DIR={{ colossus_legal_documents_container_path }}/system_prompts
SURYA_OCR_URL=http://10.10.0.99:8340
RUST_LOG={{ colossus_legal_rust_log }}
CORS_ALLOWED_ORIGINS={{ colossus_legal_cors_origins }}
AUTH_MODE=required
AUTH_LOGOUT_URL={{ colossus_legal_auth_logout_url }}
COLOSSUS_ENVIRONMENT={{ 'dev' if 'dev' in group_names else 'prod' }}
CASE_DEFAULT_SUBJECT_NAME={{ colossus_legal_case_default_subject_name | default('Marie Awad') }}

# LLM_MODEL is read by the v2 pipeline's colossus_extract factory
# (separate from ANTHROPIC_MODEL which is read by the legacy RAG path).
# Both point at the same colossus_legal_anthropic_model value —
# same model, two consumers.
LLM_MODEL={{ colossus_legal_anthropic_model | default('claude-sonnet-4-6') }}

EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL=NomicEmbedTextV15

# Restate SDK endpoint — port the backend listens on for Restate callbacks.
# Restate admin registers this backend at http://<host>:9080/restate.
# Must match the PublishPort=9080:9080 entry in the backend Quadlet file.
RESTATE_LISTEN_PORT={{ colossus_legal_restate_port }}