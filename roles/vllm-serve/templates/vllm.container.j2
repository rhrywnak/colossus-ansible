# Managed by Ansible — do not edit manually
# Platform: colossus-llm1 | Instance: {{ item.name }} | Image: {{ vllm_image }}

[Unit]
Description=vLLM {{ item.name }} ({{ item.model_repo }} @ {{ item.revision[:12] }})
After=network-online.target
Wants=network-online.target

[Container]
Image={{ vllm_image }}
ContainerName=vllm-{{ item.name }}
Network=host
{% for g in item.gpus.split(',') %}
AddDevice=nvidia.com/gpu={{ g }}
{% endfor %}
PodmanArgs=--shm-size=8g
EnvironmentFile={{ vllm_env_dir }}/vllm-{{ item.name }}.env
Environment=HF_HOME=/models
Volume={{ vllm_models_dir }}:/models:rw
Exec=vllm serve --config /models/configs/{{ item.name }}.yaml

[Service]
Restart=always
RestartSec=10
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target default.target
