# Managed by Ansible — do not edit manually
# Per-model vLLM serve config: {{ item.name }}
# Rendered to /models/configs/{{ item.name }}.yaml. To make it active, cp it onto
# the fixed layout path (/models/configs/<layout>.yaml) + restart that unit.
# Keys are long CLI flags without the leading '--' (dashes, not underscores).
model: {{ item.model_repo }}
revision: "{{ item.revision }}"
quantization: {{ item.quantization }}
tensor-parallel-size: {{ item.tensor_parallel }}
max-model-len: {{ item.max_model_len }}
max-num-seqs: {{ item.max_num_seqs }}
gpu-memory-utilization: {{ item.gpu_memory_utilization }}
port: {{ vllm_port }}
download-dir: /models
