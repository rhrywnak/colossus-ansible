# {{ ansible_managed }}
# =============================================================================
# Traefik Dynamic Configuration — Routers, Services & Middlewares
# =============================================================================
# This file is managed by Ansible (role: traefik-route).
# Manual edits will be overwritten on the next playbook run.
# Hot-reloaded by Traefik — no restart needed after changes.
# =============================================================================

http:
  # ==========================================================================
  # MIDDLEWARES
  # ==========================================================================
  middlewares:
    # Redirect HTTP → HTTPS (LAN browsers only — see priority notes)
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true

{% if traefik_auth is defined and traefik_auth.enabled | default(false) %}
    # Authentik ForwardAuth — verifies session cookie, injects identity headers
    {{ traefik_auth.name }}:
      forwardAuth:
        address: "{{ traefik_auth.address }}"
        trustForwardHeader: true
        authResponseHeaders:
{% for header in traefik_auth.response_headers %}
          - "{{ header }}"
{% endfor %}
{% endif %}

  # ==========================================================================
  # ROUTERS
  # ==========================================================================
  routers:

    # --- HTTP routers for Cloudflare Tunnel traffic (no redirect) ---
{% for route in traefik_routes if route.external | default(false) %}
    {{ route.name }}-http:
      rule: "Host(`{{ route.host }}`)"
      entryPoints:
        - http
      service: {{ route.service | default(route.name) }}
      priority: 10

{% endfor %}
{% if traefik_auth_portal is defined %}
    # --- Authentik portal HTTP (for Cloudflare Tunnel) ---
    authentik-portal-http:
      rule: "Host(`{{ traefik_auth_portal.host }}`)"
      entryPoints:
        - http
      service: authentik-server
      priority: 10

{% endif %}
    # --- HTTP catch-all: redirect LAN browsers to HTTPS ---
    # Priority 1 (lowest) — named routers on specific hosts take precedence
    http-catchall:
      rule: "HostRegexp(`.+`)"
      entryPoints:
        - http
      middlewares:
        - redirect-to-https
      service: noop@internal
      priority: 1

{% if traefik_auth_portal is defined %}
    # --- Authentik portal (auth.cogmai.com) ---
    authentik-portal:
      rule: "Host(`{{ traefik_auth_portal.host }}`)"
      entryPoints:
        - https
      service: authentik-server
      tls:
        certResolver: {{ traefik_cert_resolver }}
        domains:
          - main: "*.{{ traefik_domain }}"
            sans:
              - "{{ traefik_domain }}"

{% endif %}
    # --- HTTPS routers ---
{% for route in traefik_routes %}
    {{ route.name }}:
      rule: "Host(`{{ route.host }}`)"
      entryPoints:
        - https
      service: {{ route.service | default(route.name) }}
      priority: 10
{% if traefik_auth is defined and traefik_auth.enabled | default(false) and route.protected | default(false) %}
      middlewares:
        - {{ traefik_auth.name }}
{% endif %}
      tls:
        certResolver: {{ traefik_cert_resolver }}
        domains:
          - main: "*.{{ traefik_domain }}"
            sans:
              - "{{ traefik_domain }}"

{% if traefik_auth is defined and traefik_auth.enabled | default(false) and route.protected | default(false) %}
    # Authentik outpost path router for {{ route.name }}
    # Handles /outpost.goauthentik.io/* (login callbacks, sign_out, session mgmt)
    # Priority 15 beats the app router at 10 for the same Host
    {{ route.name }}-auth:
      rule: "Host(`{{ route.host }}`) && PathPrefix(`/outpost.goauthentik.io/`)"
      entryPoints:
        - https
      service: authentik-server
      priority: 15
      tls:
        certResolver: {{ traefik_cert_resolver }}
        domains:
          - main: "*.{{ traefik_domain }}"
            sans:
              - "{{ traefik_domain }}"

    # Logout bypass for {{ route.name }}
    # Allows /api/logout to clear cookies without ForwardAuth intercepting
    {{ route.name }}-logout:
      rule: "Host(`{{ route.host }}`) && Path(`/api/logout`)"
      entryPoints:
        - https
      service: {{ route.service | default(route.name) }}
      priority: 20
      tls:
        certResolver: {{ traefik_cert_resolver }}
        domains:
          - main: "*.{{ traefik_domain }}"
            sans:
              - "{{ traefik_domain }}"

{% endif %}
{% endfor %}
  # ==========================================================================
  # SERVICES (backend targets)
  # ==========================================================================
  services:
{% if traefik_auth_portal is defined %}
    # Authentik server — portal + outpost
    authentik-server:
      loadBalancer:
        servers:
          - url: "{{ traefik_auth_portal.backend_url }}"

{% endif %}
{% for route in traefik_routes if route.backend_url is defined %}
    {{ route.name }}:
      loadBalancer:
        servers:
          - url: "{{ route.backend_url }}"

{% endfor %}
