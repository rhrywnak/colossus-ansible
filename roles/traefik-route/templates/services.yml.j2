# {{ ansible_managed }}
# =============================================================================
# Traefik Dynamic Configuration — Routers & Services
# =============================================================================
# This file is managed by Ansible (role: traefik-route).
# Manual edits will be overwritten on the next playbook run.
# Hot-reloaded by Traefik — no restart needed after changes.
# =============================================================================

http:
  # ==========================================================================
  # MIDDLEWARES
  # ==========================================================================
  middlewares:
    # Redirect HTTP → HTTPS (LAN browsers only — see priority notes)
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true
{% if traefik_auth is defined and traefik_auth.enabled | default(false) %}

    # ForwardAuth middleware — Authentik
    # Protected routes require authentication before Traefik forwards to backend.
    # Set traefik_auth.enabled: false to bypass auth globally (emergency override).
    {{ traefik_auth.name }}:
      forwardAuth:
        address: "{{ traefik_auth.address }}"
        trustForwardHeader: true
        authResponseHeaders:
{% for header in traefik_auth.response_headers %}
          - "{{ header }}"
{% endfor %}
{% endif %}

  # ==========================================================================
  # ROUTERS
  # ==========================================================================
  routers:
{% if traefik_auth_portal is defined and traefik_auth_portal.host is defined %}

    # --- Authentik outpost callback (priority 15) ---
    # Catches /outpost.goauthentik.io/ on ALL hosts for auth flow callbacks.
    # Must be higher priority than application routers.
    authentik-outpost:
      rule: "PathPrefix(`/outpost.goauthentik.io/`)"
      entryPoints:
        - https
      service: authentik-portal
      priority: 15
      tls:
        certResolver: {{ traefik_cert_resolver }}
        domains:
          - main: "*.{{ traefik_domain }}"
            sans:
              - "{{ traefik_domain }}"

    authentik-outpost-http:
      rule: "PathPrefix(`/outpost.goauthentik.io/`)"
      entryPoints:
        - http
      service: authentik-portal
      priority: 15

    # --- Authentik portal (auth.cogmai.com) ---
    authentik-portal:
      rule: "Host(`{{ traefik_auth_portal.host }}`)"
      entryPoints:
        - https
      service: authentik-portal
      tls:
        certResolver: {{ traefik_cert_resolver }}
        domains:
          - main: "*.{{ traefik_domain }}"
            sans:
              - "{{ traefik_domain }}"

    authentik-portal-http:
      rule: "Host(`{{ traefik_auth_portal.host }}`)"
      entryPoints:
        - http
      service: authentik-portal
      priority: 10
{% endif %}

    # --- HTTP routers for Cloudflare Tunnel traffic (no redirect) ---
{% for route in traefik_routes if route.external | default(false) %}
    {{ route.name }}-http:
      rule: "Host(`{{ route.host }}`)"
      entryPoints:
        - http
      service: {{ route.service | default(route.name) }}
      priority: 10
{% if not loop.last %}

{% endif %}
{% endfor %}

    # --- HTTP catch-all: redirect LAN browsers to HTTPS ---
    # Priority 1 (lowest) — named routers on specific hosts take precedence
    http-catchall:
      rule: "HostRegexp(`.+`)"
      entryPoints:
        - http
      middlewares:
        - redirect-to-https
      service: noop@internal
      priority: 1

    # --- HTTPS routers ---
{% for route in traefik_routes %}
    {{ route.name }}:
      rule: "Host(`{{ route.host }}`)"
      entryPoints:
        - https
{% if route.protected | default(false) and traefik_auth is defined and traefik_auth.enabled | default(false) %}
      middlewares:
        - {{ traefik_auth.name }}
{% endif %}
      service: {{ route.service | default(route.name) }}
      tls:
        certResolver: {{ traefik_cert_resolver }}
        domains:
          - main: "*.{{ traefik_domain }}"
            sans:
              - "{{ traefik_domain }}"
{% if not loop.last %}

{% endif %}
{% endfor %}

  # ==========================================================================
  # SERVICES (backend targets)
  # ==========================================================================
  services:
{% if traefik_auth_portal is defined and traefik_auth_portal.backend_url is defined %}
    authentik-portal:
      loadBalancer:
        servers:
          - url: "{{ traefik_auth_portal.backend_url }}"

{% endif %}
{% for route in traefik_routes if route.backend_url is defined %}
    {{ route.name }}:
      loadBalancer:
        servers:
          - url: "{{ route.backend_url }}"
{% if not loop.last %}

{% endif %}
{% endfor %}
